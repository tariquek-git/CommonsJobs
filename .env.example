# Storage
STORAGE_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JOBS_TABLE=jobs
SUPABASE_CLICKS_TABLE=clicks

# Admin Auth
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
ADMIN_TOKEN_SECRET=

# CORS
CLIENT_ORIGIN=http://localhost:5173

# Proxy
TRUST_PROXY=1

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=
AI_TIMEOUT_MS=8000

# Email (Resend)
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=

# Vercel Cron (used to authenticate scheduled aggregation)
CRON_SECRET=

# Rate Limiting (Upstash Redis — optional, falls back to in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Analytics (PostHog — client-side, prefix with VITE_)
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error Tracking (Sentry — client-side, prefix with VITE_)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Sentry Source Maps (build-time only, set in Vercel env vars)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
